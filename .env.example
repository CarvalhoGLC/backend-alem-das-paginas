# Ao instalar a integração Postgres (Neon) pelo Vercel Marketplace, a
# variável DATABASE_URL é injetada automaticamente no seu projeto na Vercel.
#
# Para rodar localmente com "vercel dev", baixe as variáveis reais com:
#   vercel env pull .env.local
#
# Se preferir configurar manualmente (ex.: apontando para um projeto Neon
# próprio, fora do Marketplace), copie este arquivo para ".env.local" e
# preencha com a connection string do seu banco:
DATABASE_URL=postgresql://usuario:senha@ep-exemplo.neon.tech/neondb?sslmode=require
